{
  "manifest_version": 3,
  "name": "Floating Audio Sequencer",
  "version": "1.0.0",
  "description": "Click the floating button to play or pause audio in the current viewport.",
  "permissions": ["debugger", "webNavigation"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
